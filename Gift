            <div class="deco-star st4">⭐</div>

            <!-- Nailong Full Body -->
            <div class="nailong-fullbody" style="animation-delay: 0.9s;">
                <div class="nailong-avatar" style="margin-bottom:0; z-index:4;">
                    <div class="nailong-horn"></div>
                    <div class="nailong-eyes left" style="width:12px; height:4px; background:transparent; border-top:3px solid #333; border-radius:50%"></div>
