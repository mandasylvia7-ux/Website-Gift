    </div>

    <!-- TAMPILAN COPYRIGHT DI BAWAH LAYAR -->
    <div class="copyright">
        &copy; 2026 Made with 💛 by manda. All Rights Reserved.
    </div>

    <!-- JAVASCRIPT NAVIGASI MAJU MUNDUR -->
    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function changePage(direction) {
            const currentEl = document.getElementById('p' + currentStep);
            currentEl.classList.remove('active');
            
            if (direction === 1) {
                currentEl.classList.add('passed');
            }

            currentStep += direction;

            if (currentStep < 1) currentStep = 1;
            if (currentStep > totalSteps) currentStep = totalSteps;

            const nextEl = document.getElementById('p' + currentStep);
            nextEl.classList.remove('passed');
            nextEl.classList.add('active');
        }
    </script>
</body>
