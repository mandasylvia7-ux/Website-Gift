            <div class="deco-flower fl-mid-left"><div class="flower-core"></div></div>
            <div class="deco-flower fl-bot-right"><div class="flower-core"></div></div>
            <div class="deco-star st1">⭐</div>
            <div class="deco-star st4">✨</div>

            <!-- Nailong Full Body -->
            <div class="nailong-fullbody" style="animation-delay: 0.3s;">
                <div class="nailong-avatar" style="margin-bottom:0; z-index:4;">
                    <div class="nailong-horn"></div>
